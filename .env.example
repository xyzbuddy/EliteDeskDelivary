# Environment Configuration
BOT_TOKEN=your_telegram_bot_token
ADMIN_ID=your_telegram_admin_id

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/elitedesk_db
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password
DB_NAME=elitedesk_db

# Telegram Channels
ADMIN_LOG_CHANNEL_ID=your_admin_log_channel_id
MANDATORY_CHANNEL_ID=your_mandatory_channel_id

# Bot Settings
REDEEM_RATE_LIMIT=3
REDEEM_RATE_WINDOW=60
AUTO_DELETE_TIMEOUT=900
SUPPORT_USERNAME=@support
SUPPORT_REPLY_TIME=5-10 minutes
